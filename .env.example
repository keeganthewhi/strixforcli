# strixnoapi environment configuration
# Copy to .env and edit. Never commit .env.

# -----------------------------------------------------------------------------
# CLI subscription mode
# -----------------------------------------------------------------------------
# Which CLI subscription to route LLM calls through.
#   claude  -> Claude Max/Pro (OAuth in ~/.claude/.credentials.json)
#   codex   -> ChatGPT Plus/Pro (session in ~/.codex/auth.json)
#   gemini  -> Google subscription (OAuth in ~/.gemini/oauth_creds.json)
#   cursor  -> Cursor Pro (session in ~/.cursor/)
#   auto    -> pick the first authenticated CLI in the order above
#   (unset) -> fall through to upstream Strix API-key mode (requires STRIX_LLM + LLM_API_KEY)
STRIX_CLI_MODE=auto

# -----------------------------------------------------------------------------
# Proxy server (usually left at defaults)
# -----------------------------------------------------------------------------
# Bind host (must be 127.0.0.1 — overriding is blocked as a safety invariant)
# STRIX_PROXY_HOST=127.0.0.1

# Fixed port (default: ephemeral). Only set this if you have a specific reason.
# STRIX_PROXY_PORT=

# Rate limit: requests per minute, proxy-side.
# STRIX_PROXY_RATE_LIMIT=30

# Inactivity timeout for upstream API calls (seconds).
# STRIX_PROXY_INACTIVITY_S=1800

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Log full prompts to audit log. OFF by default for privacy.
# STRIX_LOG_PROMPTS=0

# Refuse to start if config file permissions are loose (default: 1, recommended on).
# STRIX_ENFORCE_PERMISSIONS=1

# -----------------------------------------------------------------------------
# Model selection per CLI (optional overrides)
# -----------------------------------------------------------------------------
# STRIX_CLAUDE_MODEL=claude-opus-4-7
# STRIX_CODEX_MODEL=gpt-5.4
# STRIX_GEMINI_MODEL=gemini-2.5-pro
# STRIX_CURSOR_MODEL=auto

# -----------------------------------------------------------------------------
# Upstream Strix (unchanged — only relevant in API-key fallback mode)
# -----------------------------------------------------------------------------
# STRIX_LLM=openai/gpt-5.4
# LLM_API_KEY=

# -----------------------------------------------------------------------------
# Telemetry (OFF by default in strixnoapi)
# -----------------------------------------------------------------------------
STRIX_TELEMETRY=0
